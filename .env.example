######################################
# Host & Network Settings
######################################
# Ports exposed on the Docker host (change these to avoid clashes with other stacks)
CKAN_PORT_HOST=5000
NGINX_PORT_HOST=81
NGINX_SSLPORT_HOST=8443

# Ports used inside the Docker network (usually leave these as-is)
CKAN_PORT=5000
NGINX_PORT=80
NGINX_SSLPORT=443

######################################
# Database Settings
######################################
# Postgres server superuser, used to create the CKAN and DataStore databases on first start
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_HOST=db

# CKAN's own database and the user CKAN connects with
CKAN_DB_USER=ckandbuser
CKAN_DB_PASSWORD=ckandbpassword
CKAN_DB=ckandb
CKAN_SQLALCHEMY_URL=postgresql://ckandbuser:ckandbpassword@db/ckandb

# DataStore database, plus a read-only user used for the Datastore/DataPusher API
DATASTORE_READONLY_USER=datastore_ro
DATASTORE_READONLY_PASSWORD=datastore
DATASTORE_DB=datastore
CKAN_DATASTORE_WRITE_URL=postgresql://ckandbuser:ckandbpassword@db/datastore
CKAN_DATASTORE_READ_URL=postgresql://datastore_ro:datastore@db/datastore

# Test database connections, only used when running CKAN's test suite
TEST_CKAN_SQLALCHEMY_URL=postgres://ckan:ckan@db/ckan_test
TEST_CKAN_DATASTORE_WRITE_URL=postgresql://ckan:ckan@db/datastore_test
TEST_CKAN_DATASTORE_READ_URL=postgresql://datastore_ro:datastore@db/datastore_test

######################################
# Dev Settings
######################################
USE_HTTPS_FOR_DEV=false

######################################
# CKAN Core Settings
######################################
CKAN_SITE_URL=https://localhost:8443
# Unique ID for this CKAN instance, used e.g. to namespace Redis/Solr data when several sites share infrastructure
#CKAN_SITE_ID=default
SESSION_COOKIE_NAME=ckan-localhost
WTF_CSRF_SSL_STRICT=false
# Allow users to sign up for an account via the web interface
CKAN_AUTH_CREATE_USER_VIA_WEB=false

# Branding
CKAN_SITE_TITLE=CKAN localhost
CKAN_SITE_LOGO=/base/images/logo.png
#CKAN_THEME=css/main
CKAN_SITE_CUSTOM_CSS=".masthead { background-color: #3d3d3d; }"

######################################
# Secrets
######################################
# CHANGE_ME values must be replaced with random strings for any non-local deployment
CKAN___BEAKER__SESSION__SECRET=CHANGE_ME
# See https://docs.ckan.org/en/latest/maintaining/configuration.html#api-token-settings
CKAN___API_TOKEN__JWT__ENCODE__SECRET=string:CHANGE_ME
CKAN___API_TOKEN__JWT__DECODE__SECRET=string:CHANGE_ME

######################################
# Sysadmin Account
######################################
# Created automatically on first start
CKAN_SYSADMIN_NAME=ckan_admin
CKAN_SYSADMIN_PASSWORD=test1234
CKAN_SYSADMIN_EMAIL=your_email@example.com

######################################
# E-Mail
######################################
# CKAN_SMTP_SERVER=
# CKAN_SMTP_STARTTLS=
# CKAN_SMTP_USER=
# CKAN_SMTP_PASSWORD=
# CKAN_SMTP_MAIL_FROM=
# CKAN_SMTP_REPLY_TO=
CKAN_ACTIVITY_STREAMS_EMAIL_NOTIFICATIONS=true

######################################
# Storage
######################################
# CKAN_STORAGE_PATH is internal to the official CKAN base image and should never be changed
#CKAN_STORAGE_PATH=/var/lib/ckan
# Maximum upload size for resource files, in MB
CKAN_MAX_RESOURCE_SIZE=10

TZ=UTC

######################################
# Solr
######################################
SOLR_IMAGE_VERSION=2.10-solr9
CKAN_SOLR_URL=http://solr:8983/solr/ckan
TEST_CKAN_SOLR_URL=http://solr:8983/solr/ckan

######################################
# Redis
######################################
REDIS_VERSION=6
CKAN_REDIS_URL=redis://redis:6379/1
TEST_CKAN_REDIS_URL=redis://redis:6379/1

######################################
# Datapusher
######################################
DATAPUSHER_VERSION=0.0.20
CKAN_DATAPUSHER_URL=http://datapusher:8800
CKAN__DATAPUSHER__CALLBACK_URL_BASE=http://ckan:5000
DATAPUSHER_REWRITE_RESOURCES=True
DATAPUSHER_REWRITE_URL=http://ckan:5000
# Optional: pin a specific CKAN API token for DataPusher instead of letting
# 01_setup_datapusher.sh generate one for ckan_admin on first start
#CKAN__DATAPUSHER__API_TOKEN=

######################################
# Harvest (message queue, backed by Redis)
######################################
CKAN__HARVEST__MQ__TYPE=redis
CKAN__HARVEST__MQ__HOSTNAME=redis
CKAN__HARVEST__MQ__PORT=6379
CKAN__HARVEST__MQ__REDIS_DB=1

######################################
# Extensions
######################################
## close_for_guests is currently broken
#CKAN__PLUGINS="close_for_guests datatables_view datastore datapusher email_notification envvars image_view multiuploader text_view tif_imageview"
CKAN__PLUGINS="cancel_dataset_creation dataset_metadata_automation dataset_reference datatables_view datastore datapusher email_notification envvars feature_image image_view multiuploader text_view tif_imageview user_manual"
#CKAN__PLUGINS="cancel_dataset_creation dataset_metadata_automation datatables_view datastore datapusher email_notification envvars image_view multiuploader text_view tif_imageview"

#CKAN__PLUGINS=""

######################################
# Backup
######################################
# Tag of the ghcr.io/tibhannover/ckan-backup image used by the optional `backup` service (profile "no-up")
#CKAN_BACKUP_VERSION=latest
